// kmer-GWAS pipeline — Nextflow configuration

params {
    help                   = false

    // Input
    accessions_file        = './accessions.txt'
    data_dir               = "${launchDir}/data"

    // Pipeline parameters
    num_bins               = 1500
    threshold              = 0
    count                  = 'n'       // 'y'=counts, 'n'=presence/absence
    delimiter              = 'tab'     // 'tab' or 'none'
    core                   = 'n'       // 'y'=write core k-mers file, 'n'=skip
    matrix_merge_cpus      = 32        // threads for matrix_merge (override with --matrix_merge_cpus N)
    kmer_count_memory      = 370.GB    // RAM per KMER_COUNT job (override with --kmer_count_memory 120.GB)
    matrix_merge_memory    = 370.GB    // RAM per MATRIX_MERGE job (override with --matrix_merge_memory 120.GB)
    kmer_count_time        = '5h'      // wallclock per KMER_COUNT job (override with --kmer_count_time '8h')
    matrix_merge_time      = '10h'     // wallclock per MATRIX_MERGE job (override with --matrix_merge_time '5h')
    clusterOptions         = null      // extra SLURM options, e.g. '--account=myproject --partition=highmem'
    cleanup                = true      // delete work dirs for successful tasks at end of run (disable with --cleanup false)
    singularity_cache_dir  = "${launchDir}/.singularity"  // override per HPC: --singularity_cache_dir /path/to/cache

    // Output
    output_dir             = "${launchDir}/results"

    // Optional — used only for bin estimation hint (see lib/utils.nf)
    genome_size            = null      // base-pairs, e.g. 17000000000
    sequencing_depth       = null      // coverage, e.g. 30
    available_ram_per_node = null      // GB, e.g. 128
}

// Execution reports
timeline {
    enabled = true
    file    = "${params.output_dir}/reports/timeline.html"
    overwrite = true
}
report {
    enabled = true
    file    = "${params.output_dir}/reports/report.html"
    overwrite = true
}
dag {
    enabled = true
    file    = "${params.output_dir}/reports/dag.svg"
    overwrite = true
}

cleanup = params.cleanup

profiles {
    standard {
        process.executor = 'local'
        executor {
            name   = 'local'
            cpus   = 64
            memory = '256 GB'
        }
    }

    slurm_container {
        process {
            executor       = 'slurm'
            clusterOptions = (params.clusterOptions instanceof String) ? params.clusterOptions : null
            withName: 'KMER_COUNT' {
                cpus   = 32
                memory = params.kmer_count_memory
                time   = params.kmer_count_time
            }
            withName: 'MATRIX_MERGE' {
                cpus   = params.matrix_merge_cpus
                memory = params.matrix_merge_memory
                time   = params.matrix_merge_time
            }
        }
        executor {
            queueSize       = 200
            submitRateLimit = '10 sec'
        }
        singularity {
            enabled    = true
            autoMounts = true
            cacheDir   = params.singularity_cache_dir
            runOptions = "--bind ${launchDir},${new File(params.data_dir).absolutePath},${new File(params.data_dir).canonicalPath},${new File(params.accessions_file).absoluteFile.parentFile.absolutePath},${new File(params.accessions_file).canonicalFile.parentFile.canonicalPath}"
        }
        process.container = 'ghcr.io/mjfi2sb3/kmer-gwas-cpp:v2.5.0'
    }

    slurm {
        process {
            executor       = 'slurm'
            clusterOptions = (params.clusterOptions instanceof String) ? params.clusterOptions : null
            withName: 'KMER_COUNT' {
                cpus   = 32
                memory = params.kmer_count_memory
                time   = params.kmer_count_time
            }
            withName: 'MATRIX_MERGE' {
                cpus   = params.matrix_merge_cpus
                memory = params.matrix_merge_memory
                time   = params.matrix_merge_time
            }
        }
        executor {
            queueSize       = 200
            submitRateLimit = '10 sec'
        }
    }
}
