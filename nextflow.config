// kmer-GWAS pipeline — Nextflow configuration

params {
    help                   = false

    // Input
    accessions_file        = './accessions.txt'
    data_dir               = "${launchDir}/data"

    // Pipeline parameters
    num_bins               = 1500
    threshold              = 0
    count                  = 'n'       // 'y'=counts, 'n'=presence/absence
    delimiter              = 'tab'     // 'tab' or 'none'
    core                   = 'n'       // 'y'=write core k-mers file, 'n'=skip
    matrix_merge_cpus      = 32        // threads for matrix_merge (override with --matrix_merge_cpus N)

    // Output
    output_dir             = "${launchDir}/results"

    // Optional — used only for bin estimation hint (see lib/utils.nf)
    genome_size            = null      // base-pairs, e.g. 17000000000
    sequencing_depth       = null      // coverage, e.g. 30
    available_ram_per_node = null      // GB, e.g. 128
}

// Execution reports
timeline {
    enabled = true
    file    = "${params.output_dir}/reports/timeline.html"
    overwrite = true
}
report {
    enabled = true
    file    = "${params.output_dir}/reports/report.html"
    overwrite = true
}
dag {
    enabled = true
    file    = "${params.output_dir}/reports/dag.svg"
    overwrite = true
}

profiles {
    standard {
        process.executor = 'local'
        executor {
            name   = 'local'
            cpus   = 64
            memory = '256 GB'
        }
    }

    slurm_container {
        process {
            executor = 'slurm'
            withName: 'KMER_COUNT' {
                cpus   = 32
                memory = '128 GB'
                time   = '8h'
            }
            withName: 'MATRIX_MERGE' {
                cpus   = params.matrix_merge_cpus
                memory = '64 GB'
                time   = '5h'
            }
        }
        executor {
            queueSize       = 200
            submitRateLimit = '10 sec'
        }
        singularity {
            enabled    = true
            autoMounts = true
            cacheDir   = "${HOME}/singularity_cache"
        }
        process.container = 'ghcr.io/mjfi2sb3/kmer-gwas-cpp:v2.3.0'
    }

    slurm {
        process {
            executor = 'slurm'
            withName: 'KMER_COUNT' {
                //clusterOptions = '-A k1616 -p workq --hint=nomultithread'
                cpus           = 32
                memory         = '128 GB'
                time           = '8h'
            }
            withName: 'MATRIX_MERGE' {
                //clusterOptions = '-A k1616 -p workq'
                cpus           = params.matrix_merge_cpus
                memory         = '64 GB'
                time           = '5h'
            }
        }
        executor {
            queueSize       = 200
            submitRateLimit = '10 sec'
        }
    }
}
