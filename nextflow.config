// kmer-GWAS pipeline — Nextflow configuration

params {
    // Input
    accessions_file        = './accessions.txt'
    data_dir               = './data'

    // Pipeline parameters
    num_bins               = 1500
    threshold              = 6
    count                  = 'n'       // 'y'=counts, 'n'=presence/absence
    delimiter              = 'tab'     // 'tab' or 'none'

    // Output
    output_dir             = './results'

    // Optional — used only for bin estimation hint (see lib/utils.nf)
    genome_size            = null      // base-pairs, e.g. 17000000000
    sequencing_depth       = null      // coverage, e.g. 30
    available_ram_per_node = null      // GB, e.g. 128
}

// Execution reports
timeline {
    enabled = true
    file    = "${params.output_dir}/reports/timeline.html"
    overwrite = true
}
report {
    enabled = true
    file    = "${params.output_dir}/reports/report.html"
    overwrite = true
}
dag {
    enabled = true
    file    = "${params.output_dir}/reports/dag.svg"
    overwrite = true
}

profiles {
    standard {
        process.executor = 'local'
        executor {
            name   = 'local'
            cpus   = 64
            memory = '256 GB'
        }
    }

    slurm {
        process.executor = 'slurm'
        process {
            withName: 'KMER_COUNT' {
                clusterOptions = '-A k1616 -p workq --hint=nomultithread'
                cpus           = 32
                memory         = '128 GB'
                time           = '8h'
            }
            withName: 'MATRIX_MERGE' {
                clusterOptions = '-A k1616 -p workq'
                cpus           = 1
                memory         = '64 GB'
                time           = '5h'
            }
        }
        executor {
            queueSize       = 200
            submitRateLimit = '10 sec'
        }
    }
}
